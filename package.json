{
  "name": "nextrade",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server dev",
    "dev:all": "concurrently \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/nextrade dev\" \"pnpm --filter @workspace/admin-portal dev\"",
    "build": "node build.cjs && pnpm --filter @workspace/api-server build",
    "build:all": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/nextrade build && pnpm --filter @workspace/admin-portal build",
    "start": "node artifacts/api-server/dist/index.mjs",
    "start:sh": "bash start.sh",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
